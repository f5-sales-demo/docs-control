[codespell]
skip = *.json,*.lock,*/tools/generated/*,vendor/*,*/vendored/*,*/fixtures/*,*.min.js,*.jsonl,*.b64.js,node_modules,target,dist,.git,packages/*/dist,crates/*/vendored
ignore-words-list = afterall,aks,datas,edn,hcl,ists,iterm,nd,observ,pre-select,pre-selected,pre-selects,preceeding,uncomplete,ves
